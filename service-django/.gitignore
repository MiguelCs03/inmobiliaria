# ==============================================================================
# SERVICIO: Django (.gitignore)
# ==============================================================================

# --- Caché de Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipydb_filter/

# --- Entornos Virtuales (Virtual Environments) ---
venv/
.venv/
env/
ENV/
virtualenv/
pip-selfcheck.json

# --- Configuración y Secretos ---
.env
.env.local
*.env
!.env.example

# --- Base de Datos Local ---
*.sqlite3
*.db

# --- Archivos de Media y Estáticos Generados ---
# Evita subir archivos cargados por usuarios en desarrollo
media/
# Directorio donde collectstatic compila los estáticos para producción
staticfiles/

# --- Pruebas y Cobertura (Testing & Coverage) ---
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.cache
nosetests.xml
pip-log.txt

# --- Distribución / Empaquetamiento ---
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Jupyter Notebooks ---
.ipynb_checkpoints

# --- Celery y Colas de Mensajes ---
celerybeat-schedule
celerybeat.pid

# --- Traducciones ---
*.mo
