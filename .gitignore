# ==============================================================================
# REPOSITORIO GENERAL: .gitignore Raíz
# ==============================================================================

# --- Sistema Operativo ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editores e IDEs ---
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
.history/
*.code-workspace

# JetBrains (WebStorm, PyCharm, GoLand, IntelliJ, etc.)
.idea/
*.iws
*.iml
*.ipr

# Visual Studio / MS Build
*.suo
*.user
*.userosscache
*.sln.docstates

# Sublime Text / Atom
*.sublime-project
*.sublime-workspace
.atom/

# --- Logs y Depuración ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Archivos Temporales y Caché ---
.tmp/
.temp/
tmp/
temp/
.sass-cache/
.eslintcache
.parcel-cache/
.cache/

# --- Variables de Entorno (Seguridad) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
!.env.example

# --- Paquetes / Dependencias a Nivel Raíz (si existieran) ---
node_modules/
jspm_packages/
web_modules/
.npm/
.yarn/
.pnpm-store/
